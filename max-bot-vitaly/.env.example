# Контент-машина napitki133.ru (префикс V2_ в .env)
# Запуск: python bot.py

V2_WORDPRESS_URL=https://napitki133.ru
V2_OPENROUTER_API_KEY=
V2_OPENROUTER_MODEL=google/gemini-2.0-flash-001

V2_TELEGRAM_BOT_TOKEN=
V2_TELEGRAM_CHANNEL_TRAVEL=
V2_TELEGRAM_CHANNEL_LIFHAKI=
V2_TELEGRAM_CHANNEL_DRINKS=

V2_MAX_BOT_TOKEN=
# Каналы MAX: целое chat_id или URL .../id123456789_biz (как в POST /messages). Сверка: python list_max_chats.py
V2_MAX_CHANNEL_TRAVEL=
V2_MAX_CHANNEL_LIFHAKI=
V2_MAX_CHANNEL_DRINKS=

V2_GOOGLE_CREDENTIALS_PATH=service_account.json
V2_GOOGLE_SHEET_ID=

# Опционально: реклама магазина
V2_WOO_CONSUMER_KEY=
V2_WOO_CONSUMER_SECRET=

# Опционально: URL для рекламы (есть дефолты в config)
V2_SITE_URL=https://napitki133.ru
V2_RADIO_URL=https://napitki133.ru/internet-radio-sajta-napitki133-ru/
V2_SHOP_URL=https://napitki133.ru/shop/

# Опционально: интервалы повторов (дней). Можно задать здесь или в листе Настройки.
V2_REPEAT_INTERVAL_DAYS=14
V2_SHOP_REPEAT_DAYS=21
